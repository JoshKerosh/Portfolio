---
---
<div class="bg-band" id="band-education">
<section id="education" class="fade-in">
  <div class="section-label">03 // education</div>
  <h2 class="section-title">Education</h2>
  <div class="section-divider"></div>
  <div style="display:flex;flex-direction:column;gap:20px;max-width:700px;">

    <div style="background:var(--bg-card);border:1px solid rgba(124,255,107,.25);border-radius:var(--radius);padding:28px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--green),var(--pink));"></div>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
        <div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:.74rem;color:var(--text-dim);margin-bottom:4px;">2022 – 2026</div>
          <div style="font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:3px;">B.Sc. Computer Engineering</div>
          <div style="font-size:.9rem;color:var(--green);font-weight:500;margin-bottom:3px;">Instituto Tecnológico de Costa Rica (TEC)</div>
          <div style="font-size:.78rem;color:var(--text-dim);">📍 Cartago, Costa Rica · <span style="color:var(--orange);font-weight:600;">Expected Graduation 2026</span></div>
        </div>
        <span style="font-size:.67rem;padding:4px 10px;background:rgba(255,170,68,.12);border:1px solid var(--orange);border-radius:12px;color:var(--orange);font-weight:600;font-family:'JetBrains Mono',monospace;white-space:nowrap;flex-shrink:0;">In Progress</span>
      </div>
      <div style="margin-top:18px;padding-top:18px;border-top:1px solid var(--border);">
        <div style="font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--text-dim);letter-spacing:.08em;text-transform:uppercase;margin-bottom:10px;">Areas of Focus</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          <span class="badge green">Software Engineering</span>
          <span class="badge green">Distributed Systems</span>
          <span class="badge green">Databases</span>
          <span class="badge">Computer Networks</span>
          <span class="badge">Operating Systems</span>
          <span class="badge">Algorithms &amp; Data Structures</span>
        </div>
      </div>
    </div>

  </div>
</section>
</div>
