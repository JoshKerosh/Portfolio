---
import { skillGroups } from '../data/skills';
---
<div id="skills">
  <div class="inner fade-in">
    <div class="section-label">02 // skills</div>
    <h2 class="section-title">Tech Stack</h2>
    <div class="section-divider"></div>

    <!-- legend -->
    <div class="skills-legend" style="display:flex;flex-wrap:wrap;gap:20px;margin-bottom:32px;padding:14px 18px;background:var(--bg-base);border:1px solid var(--border);border-radius:var(--radius);width:fit-content;">
      <span style="font-size:.78rem;color:var(--text-dim);font-family:'JetBrains Mono',monospace;align-self:center;">proficiency:</span>
      <span style="display:flex;align-items:center;gap:7px;font-size:.85rem;color:var(--pink);">
        <span style="width:10px;height:10px;border-radius:50%;background:var(--pink);display:inline-block;flex-shrink:0;"></span>★★★
      </span>
      <span style="display:flex;align-items:center;gap:7px;font-size:.85rem;color:var(--green);">
        <span style="width:10px;height:10px;border-radius:50%;background:var(--green);display:inline-block;flex-shrink:0;"></span>★★☆
      </span>
      <span style="display:flex;align-items:center;gap:7px;font-size:.85rem;color:var(--text-dim);">
        <span style="width:10px;height:10px;border-radius:50%;background:var(--border-hi);display:inline-block;flex-shrink:0;"></span>★☆☆
      </span>
    </div>

    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-group">
          <div class="skill-group-title"><span>{group.icon}</span> {group.title}</div>
          <div class="badges">
            {group.badges.map(b => (
              <span class={`badge${b.variant && b.variant !== 'default' ? ' ' + b.variant : ''}`}>{b.label}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
