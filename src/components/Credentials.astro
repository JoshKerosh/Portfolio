---
import { credentials } from '../data/credentials';
---
<div class="bg-band" id="band-credentials">
<section id="credentials" class="fade-in">
  <div class="section-label">04 // credentials</div>
  <h2 class="section-title">Credentials</h2>
  <div class="section-divider"></div>
  <div class="certs-grid">
    {credentials.map(c => (
      <div class="cert-card">
        <div class="cert-icon">{c.icon}</div>
        <div>
          <div class="cert-name">{c.name}</div>
          <div class="cert-issuer">{c.issuer}</div>
          {c.verifyUrl && (
            <a href={c.verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-link">↗ Verify credential</a>
          )}
          {c.wip && <span class="cert-wip">In Progress</span>}
        </div>
      </div>
    ))}
  </div>
</section>
</div>
